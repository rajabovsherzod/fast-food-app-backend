# ================================
# SERVER
# ================================
NODE_ENV=production
PORT=5000

# ================================
# DATABASE (Railway PostgreSQL)
# ================================
DATABASE_URL=postgresql://user:password@host:5432/railway

# ================================
# JWT (100 yillik tokenlar)
# ================================
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-here
JWT_EXPIRES_IN=36500d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars
JWT_REFRESH_EXPIRES_IN=36500d

# ================================
# TELEGRAM BOT
# ================================
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_ADMIN_CHAT_ID=your-admin-telegram-chat-id

# ================================
# URLS (deploy qilgandan keyin to'ldiring)
# ================================
PUBLIC_URL=https://your-backend.railway.app
WEB_APP_URL=https://your-user-app.vercel.app
CLIENT_URL=https://your-user-app.vercel.app
ADMIN_URL=https://your-admin-panel.vercel.app

# ================================
# UPLOADS (Railway Volume - /data/uploads)
# ================================
UPLOAD_DIR=/data/uploads
MAX_FILE_SIZE=5242880

# ================================
# SETTINGS
# ================================
DEFAULT_DELIVERY_PRICE=15000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
